import React, { useState, useEffect, useMemo } from 'react';
import { 
  PlusCircle, MinusCircle, Wallet, Download, Trash2, PieChart, CreditCard,
  TrendingUp, TrendingDown, Sparkles, Wand2, Loader2, Lightbulb, RefreshCw,
  Home, Zap, Dumbbell, PlaySquare, HeartPulse, PartyPopper, Plane, Glasses, 
  BookOpen, MoreHorizontal, Utensils, AlertTriangle, Target, Landmark, ArrowRightLeft,
  Edit2, X, Cloud
} from 'lucide-react';

import { initializeApp } from 'firebase/app';
import { getAuth, signInWithCustomToken, signInAnonymously, onAuthStateChanged } from 'firebase/auth';
import { getFirestore, collection, doc, setDoc, onSnapshot, deleteDoc } from 'firebase/firestore';

const apiKey = ""; // La clave API será inyectada automáticamente por el entorno

// Inicialización de Firebase en la Nube
let db, auth, appId;
try {
  const firebaseConfig = typeof __firebase_config !== 'undefined' ? JSON.parse(__firebase_config) : {};
  const app = initializeApp(firebaseConfig);
  auth = getAuth(app);
  db = getFirestore(app);
  appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';
} catch (e) {
  console.error("Error inicializando la base de datos:", e);
}

const App = () => {
  // --- ESTADOS GLOBALES ---
  const [activeTab, setActiveTab] = useState('movimientos');
  
  // Cuentas por defecto
  const [accounts, setAccounts] = useState([
    { id: 'acc-1', name: 'Cuenta de Ahorros', type: 'banco', balance: 0 },
    { id: 'acc-2', name: 'Tarjeta de Crédito', type: 'tarjeta', balance: 0 },
  ]);
  
  const [transactions, setTransactions] = useState([]);
  const [budgets, setBudgets] = useState({}); // { 'Comida': 500000, ... }
  const [fixedExpenses, setFixedExpenses] = useState([
    { id: 'f1', title: 'Arriendo', amount: 1200000, category: 'Arriendo', accountId: 'acc-1', isPaid: false }
  ]);

  // Estado para edición de cuentas
  const [editingAccount, setEditingAccount] = useState(null);

  // Estados UI y Formularios
  const [type, setType] = useState('gasto');
  const [amount, setAmount] = useState('');
  const [category, setCategory] = useState('Comida');
  const [accountId, setAccountId] = useState('acc-1');
  const [toAccountId, setToAccountId] = useState('acc-2'); // Para transferencias
  const [description, setDescription] = useState('');
  const [date, setDate] = useState(new Date().toISOString().split('T')[0]);

  // Estados IA
  const [magicPrompt, setMagicPrompt] = useState('');
  const [isMagicLoading, setIsMagicLoading] = useState(false);
  const [categoryAnalysis, setCategoryAnalysis] = useState('');
  const [isAnalysisLoading, setIsAnalysisLoading] = useState(false);

  // --- ESTADOS DE LA BASE DE DATOS ---
  const [user, setUser] = useState(null);
  const [isSyncing, setIsSyncing] = useState(false);

  useEffect(() => {
    if(!auth) return;
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch(e) {
        console.error("Auth error", e);
      }
    };
    initAuth();
    const unsubscribe = onAuthStateChanged(auth, setUser);
    return () => unsubscribe();
  }, []);

  useEffect(() => {
    if (!user || !db) return;

    const unsubSettings = onSnapshot(
      doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'main'), 
      (docSnap) => {
        if (docSnap.exists()) {
          const data = docSnap.data();
          if (data.accounts) setAccounts(data.accounts);
          if (data.categoriesConfig) setCategoriesConfig(data.categoriesConfig);
          if (data.budgets) setBudgets(data.budgets);
          if (data.fixedExpenses) setFixedExpenses(data.fixedExpenses);
        }
      },
      (err) => console.error(err)
    );

    const unsubTx = onSnapshot(
      collection(db, 'artifacts', appId, 'users', user.uid, 'transactions'), 
      (snap) => {
        const txs = [];
        snap.forEach(d => txs.push({id: d.id, ...d.data()}));
        txs.sort((a,b) => new Date(b.date) - new Date(a.date));
        setTransactions(txs);
      },
      (err) => console.error(err)
    );

    return () => { unsubSettings(); unsubTx(); };
  }, [user]);

  const updateCloudSettings = async (key, value) => {
    if (!user || !db) return;
    setIsSyncing(true);
    try {
      await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'main'), {
        [key]: value
      }, { merge: true });
    } catch (e) {
      console.error("Error guardando en la nube:", e);
    } finally {
      setIsSyncing(false);
    }
  };

  // --- CONFIGURACIÓN DE CATEGORÍAS ---
  const [categoriesConfig, setCategoriesConfig] = useState([
    { name: 'Comida', type: 'gasto' },
    { name: 'Arriendo', type: 'gasto' },
    { name: 'Servicios', type: 'gasto' },
    { name: 'Deporte', type: 'gasto' },
    { name: 'Suscripciones', type: 'gasto' },
    { name: 'Salud', type: 'gasto' },
    { name: 'Deudas', type: 'gasto' },
    { name: 'Salidas', type: 'gasto' },
    { name: 'Viajes', type: 'gasto' },
    { name: 'Sajú', type: 'gasto' },
    { name: 'Libros', type: 'gasto' },
    { name: 'Otros', type: 'ambos' },
    { name: 'Salario', type: 'ingreso' },
    { name: 'Honorarios', type: 'ingreso' }
  ]);
  
  const categoryIconMap = {
    'Comida': Utensils, 'Arriendo': Home, 'Servicios': Zap, 'Deporte': Dumbbell,
    'Suscripciones': PlaySquare, 'Salud': HeartPulse, 'Deudas': CreditCard,
    'Salidas': PartyPopper, 'Viajes': Plane, 'Sajú': Glasses, 'Libros': BookOpen,
    'Salario': Wallet, 'Honorarios': TrendingUp
  };

  const expenseCategories = categoriesConfig.filter(c => c.type === 'gasto' || c.type === 'ambos').map(c => c.name);
  const incomeCategories = categoriesConfig.filter(c => c.type === 'ingreso' || c.type === 'ambos').map(c => c.name);

  // --- CÁLCULOS Y DERIVADOS ---
  // Calcular saldos reales basados en transacciones
  const calculatedAccounts = useMemo(() => {
    return accounts.map(acc => {
      let currentBalance = acc.balance;
      transactions.forEach(t => {
        if (t.type === 'ingreso' && t.accountId === acc.id) currentBalance += t.amount;
        if (t.type === 'gasto' && t.accountId === acc.id) currentBalance -= t.amount;
        if (t.type === 'transferencia') {
          if (t.accountId === acc.id) currentBalance -= t.amount; // Sale de aquí
          if (t.toAccountId === acc.id) currentBalance += t.amount; // Entra aquí
        }
      });
      return { ...acc, currentBalance };
    });
  }, [accounts, transactions]);

  const totalAssets = calculatedAccounts.filter(a => a.type === 'banco').reduce((sum, a) => sum + a.currentBalance, 0);
  const totalLiabilities = calculatedAccounts.filter(a => a.type === 'tarjeta' || a.type === 'deuda').reduce((sum, a) => sum + a.currentBalance, 0);
  const netWorth = totalAssets + totalLiabilities; // Liabilities suelen ser negativos o los restamos si los guardamos positivos. Asumimos saldo negativo = deuda

  // Gasto por categoría
  const expensesByCategory = useMemo(() => {
    const sums = {};
    expenseCategories.forEach(c => sums[c] = 0);
    transactions.forEach(t => {
      if (t.type === 'gasto') {
        sums[t.category] = (sums[t.category] || 0) + t.amount;
      }
    });
    return sums;
  }, [transactions]);

  // Indicadores de tiempo (Semana y Mes)
  const { weeklyExpense, monthlyExpense, monthlyIncome } = useMemo(() => {
    const now = new Date();
    const currentMonth = now.getMonth();
    const currentYear = now.getFullYear();

    // Calcular el lunes de esta semana
    const startOfWeek = new Date(now);
    const day = startOfWeek.getDay() || 7; // Convertir domingo (0) a 7
    if (day !== 1) startOfWeek.setHours(-24 * (day - 1));
    startOfWeek.setHours(0, 0, 0, 0);

    let wExpense = 0;
    let mExpense = 0;
    let mIncome = 0;

    transactions.forEach(t => {
      // Parsear a mediodía para evitar saltos de día por zona horaria
      const tDate = new Date(t.date + 'T12:00:00');

      const isThisMonth = tDate.getMonth() === currentMonth && tDate.getFullYear() === currentYear;
      const isThisWeek = tDate >= startOfWeek;

      if (t.type === 'gasto') {
        if (isThisMonth) mExpense += t.amount;
        if (isThisWeek) wExpense += t.amount;
      } else if (t.type === 'ingreso') {
        if (isThisMonth) mIncome += t.amount;
      }
    });

    return { weeklyExpense: wExpense, monthlyExpense: mExpense, monthlyIncome: mIncome };
  }, [transactions]);

  // --- UTILIDADES ---
  const formatCurrency = (value) => {
    return new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', minimumFractionDigits: 0 }).format(value);
  };

  const getCategoryIcon = (catName) => {
    const IconComponent = categoryIconMap[catName] || MoreHorizontal;
    return <IconComponent size={16} className="inline mr-1" />;
  };

  const fetchWithRetry = async (url, options, retries = 5) => {
    const delays = [1000, 2000, 4000, 8000, 16000];
    for (let i = 0; i < retries; i++) {
      try {
        const response = await fetch(url, options);
        if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
        return await response.json();
      } catch (error) {
        if (i === retries - 1) throw error;
        await new Promise(res => setTimeout(res, delays[i]));
      }
    }
  };

  // --- FUNCIONES IA (GEMINI) ---
  const handleMagicInput = async () => {
    if (!magicPrompt.trim()) return;
    setIsMagicLoading(true);

    try {
      const today = new Date().toISOString().split('T')[0];
      const accountsListStr = accounts.map(a => `ID: "${a.id}", Nombre: "${a.name}"`).join(' | ');
      
      const payload = {
        contents: [{ parts: [{ text: magicPrompt }] }],
        systemInstruction: {
          parts: [{
            text: `Eres un asistente financiero. Extrae los datos en JSON.
            Reglas:
            - type: "gasto" o "ingreso"
            - amount: número entero. Entiende "lucas" o "k" como miles.
            - category: SOLO UNA DE ESTAS EXACTAMENTE: [${categoriesConfig.map(c=>c.name).join(', ')}].
            - accountId: Analiza con qué pagó y elige el ID de cuenta que mejor encaje de esta lista: [${accountsListStr}]. Si no está claro, usa el primer ID.
            - description: Resumen de máximo 4 palabras.
            - date: YYYY-MM-DD. Hoy es ${today}.`
          }]
        },
        generationConfig: {
          responseMimeType: "application/json",
          responseSchema: {
            type: "OBJECT",
            properties: {
              type: { type: "STRING" },
              amount: { type: "NUMBER" },
              category: { type: "STRING" },
              accountId: { type: "STRING" },
              description: { type: "STRING" },
              date: { type: "STRING" }
            },
            required: ["type", "amount", "category", "accountId", "description", "date"]
          }
        }
      };

      const result = await fetchWithRetry(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
        { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) }
      );

      const parsedData = JSON.parse(result.candidates[0].content.parts[0].text);
      
      if (user && db) {
        const newTransaction = { id: crypto.randomUUID(), ...parsedData, amount: parseFloat(parsedData.amount) };
        await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'transactions', newTransaction.id), newTransaction);
      }
      
      setType(parsedData.type);
      setAmount(parsedData.amount.toString());
      setCategory(parsedData.category);
      setAccountId(parsedData.accountId);
      setDescription(parsedData.description);
      setDate(parsedData.date);
      setMagicPrompt('');
    } catch (error) {
      console.error("Error Magic Input:", error);
    } finally {
      setIsMagicLoading(false);
    }
  };

  const getCategoryAnalysisWithAI = async () => {
    setIsAnalysisLoading(true);
    try {
      const totalsStr = Object.entries(expensesByCategory)
        .filter(([_, amount]) => amount > 0)
        .map(([cat, amount]) => `- ${cat}: ${formatCurrency(amount)}`)
        .join('\n');
        
      const budgetStr = Object.entries(budgets)
        .map(([cat, limit]) => `- Presupuesto ${cat}: ${formatCurrency(limit)}`)
        .join('\n');

      const prompt = `Aquí están mis gastos totales por categoría este mes:\n${totalsStr}\n\nMis límites de presupuesto son:\n${budgetStr}\n\nPor favor, actúa como mi asesor financiero personal. Haz un análisis de estos gastos. ¿En qué estoy gastando demasiado? ¿Qué categoría requiere atención inmediata según mis presupuestos o hábitos comunes? Dame un consejo estratégico, usando un tono motivador y en español. Mantén la respuesta en 2 o 3 párrafos cortos y usa viñetas si es necesario.`;

      const payload = { contents: [{ parts: [{ text: prompt }] }] };

      const result = await fetchWithRetry(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
        { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) }
      );

      setCategoryAnalysis(result.candidates[0].content.parts[0].text);
    } catch (error) {
      setCategoryAnalysis("Hubo un error al generar el análisis. Inténtalo de nuevo.");
    } finally {
      setIsAnalysisLoading(false);
    }
  };

  // --- MANEJADORES DE EVENTOS ---
  const handleTransactionSubmit = async (e) => {
    e.preventDefault();
    if (!amount || !description) return;

    const newTransaction = {
      id: crypto.randomUUID(),
      type,
      amount: parseFloat(amount),
      category: type === 'transferencia' ? 'Transferencia' : category,
      accountId,
      toAccountId: type === 'transferencia' ? toAccountId : null,
      description,
      date
    };

    if (user && db) {
      setIsSyncing(true);
      await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'transactions', newTransaction.id), newTransaction);
      setIsSyncing(false);
    } else {
      setTransactions([newTransaction, ...transactions]);
    }
    
    setAmount('');
    setDescription('');
  };

  const deleteTransaction = async (id) => {
    if (user && db) {
      setIsSyncing(true);
      await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'transactions', id));
      setIsSyncing(false);
    } else {
      setTransactions(transactions.filter(t => t.id !== id));
    }
  };

  const handlePayFixedExpense = async (expense) => {
    const newTransaction = {
      id: crypto.randomUUID(),
      type: 'gasto',
      amount: expense.amount,
      category: expense.category,
      accountId: expense.accountId,
      description: `Pago Fijo: ${expense.title}`,
      date: new Date().toISOString().split('T')[0]
    };
    
    const newFixedExpenses = fixedExpenses.map(f => f.id === expense.id ? { ...f, isPaid: true } : f);

    if (user && db) {
      setIsSyncing(true);
      await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'transactions', newTransaction.id), newTransaction);
      await updateCloudSettings('fixedExpenses', newFixedExpenses);
      setIsSyncing(false);
    } else {
      setTransactions([newTransaction, ...transactions]);
      setFixedExpenses(newFixedExpenses);
    }
  };

  const addAccount = (e) => {
    e.preventDefault();
    const name = e.target.accName.value;
    const type = e.target.accType.value;
    const initialBalance = parseFloat(e.target.accBalance.value || 0);
    if(name) {
      const newAccounts = [...accounts, { id: crypto.randomUUID(), name, type, balance: initialBalance }];
      if (user && db) updateCloudSettings('accounts', newAccounts);
      else setAccounts(newAccounts);
      e.target.reset();
    }
  };

  const addCategory = (e) => {
    e.preventDefault();
    const name = e.target.catName.value.trim();
    const type = e.target.catType.value;
    
    if (name && !categoriesConfig.find(c => c.name.toLowerCase() === name.toLowerCase())) {
      const formattedName = name.charAt(0).toUpperCase() + name.slice(1);
      const newCategories = [...categoriesConfig, { name: formattedName, type }];
      if (user && db) updateCloudSettings('categoriesConfig', newCategories);
      else setCategoriesConfig(newCategories);
      e.target.reset();
    }
  };

  const deleteCategory = (catName) => {
    const newCategories = categoriesConfig.filter(c => c.name !== catName);
    if (user && db) updateCloudSettings('categoriesConfig', newCategories);
    else setCategoriesConfig(newCategories);
  };

  const deleteAccount = (id) => {
    const newAccounts = accounts.filter(a => a.id !== id);
    if (user && db) updateCloudSettings('accounts', newAccounts);
    else setAccounts(newAccounts);
  };

  const handleUpdateAccount = (e) => {
    e.preventDefault();
    const newAccounts = accounts.map(acc => acc.id === editingAccount.id ? editingAccount : acc);
    if (user && db) updateCloudSettings('accounts', newAccounts);
    else setAccounts(newAccounts);
    setEditingAccount(null);
  };

  const saveBudget = (e) => {
    e.preventDefault();
    const cat = e.target.budgetCat.value;
    const limit = parseFloat(e.target.budgetAmount.value);
    if(cat && limit) {
      const newBudgets = { ...budgets, [cat]: limit };
      if (user && db) updateCloudSettings('budgets', newBudgets);
      else setBudgets(newBudgets);
      e.target.reset();
    }
  };

  const exportToCSV = () => {
    if (transactions.length === 0) return;
    const headers = ['Fecha', 'Tipo', 'Categoría', 'Cuenta Origen', 'Cuenta Destino', 'Descripción', 'Monto'];
    const rows = transactions.map(t => [
      t.date, t.type.toUpperCase(), t.category, 
      accounts.find(a=>a.id === t.accountId)?.name || '', 
      t.toAccountId ? (accounts.find(a=>a.id === t.toAccountId)?.name || '') : '',
      t.description, t.amount
    ]);
    const csvContent = "data:text/csv;charset=utf-8," + [headers.join(","), ...rows.map(e => e.join(","))].join("\n");
    const encodedUri = encodeURI(csvContent);
    const link = document.createElement("a");
    link.setAttribute("href", encodedUri);
    link.setAttribute("download", `finanzas_${new Date().toISOString().split('T')[0]}.csv`);
    document.body.appendChild(link); link.click(); document.body.removeChild(link);
  };

  // --- COMPONENTES DE VISTA ---
  const renderMovimientos = () => (
    <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
      {/* Columna Izquierda: Formularios */}
      <div className="lg:col-span-1 space-y-6">
        {/* Ingreso Mágico */}
        <div className="bg-gradient-to-br from-indigo-600 to-purple-700 p-6 rounded-2xl shadow-md text-white">
          <h2 className="text-lg font-bold mb-2 flex items-center gap-2"><Wand2 size={20} /> Ingreso Mágico ✨</h2>
          <textarea 
            value={magicPrompt} onChange={(e) => setMagicPrompt(e.target.value)}
            placeholder="Ej: Gasté 20k en Comida y pagué con Tarjeta de Crédito..."
            className="w-full p-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-indigo-200 focus:outline-none focus:ring-2 focus:ring-white/50 resize-none text-sm h-24 mb-3"
          />
          <button 
            onClick={handleMagicInput} disabled={isMagicLoading || !magicPrompt.trim()}
            className="w-full flex items-center justify-center gap-2 py-2.5 bg-white text-indigo-700 hover:bg-indigo-50 font-bold rounded-xl transition-colors disabled:opacity-70"
          >
            {isMagicLoading ? <><Loader2 size={18} className="animate-spin" /> Procesando...</> : <><Sparkles size={18} /> Autocompletar ✨</>}
          </button>
        </div>

        {/* Formulario Manual */}
        <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
          <form onSubmit={handleTransactionSubmit} className="space-y-4">
            <div className="flex rounded-lg overflow-hidden border border-slate-200 p-1 bg-slate-50">
              <button type="button" onClick={() => setType('gasto')} className={`flex-1 py-1.5 flex justify-center gap-1 text-sm font-medium rounded-md ${type === 'gasto' ? 'bg-white shadow text-rose-600' : 'text-slate-500'}`}><MinusCircle size={14} /> Gasto</button>
              <button type="button" onClick={() => setType('ingreso')} className={`flex-1 py-1.5 flex justify-center gap-1 text-sm font-medium rounded-md ${type === 'ingreso' ? 'bg-white shadow text-emerald-600' : 'text-slate-500'}`}><PlusCircle size={14} /> Ingreso</button>
              <button type="button" onClick={() => setType('transferencia')} className={`flex-1 py-1.5 flex justify-center gap-1 text-sm font-medium rounded-md ${type === 'transferencia' ? 'bg-white shadow text-indigo-600' : 'text-slate-500'}`}><ArrowRightLeft size={14} /> Traspaso</button>
            </div>

            <div className="grid grid-cols-2 gap-3">
              <div>
                <label className="text-xs font-semibold text-slate-500 uppercase">Monto</label>
                <input type="number" value={amount} onChange={(e) => setAmount(e.target.value)} className="w-full p-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500" required />
              </div>
              <div>
                <label className="text-xs font-semibold text-slate-500 uppercase">Fecha</label>
                <input type="date" value={date} onChange={(e) => setDate(e.target.value)} className="w-full p-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500" required />
              </div>
            </div>

            {type !== 'transferencia' && (
              <div>
                <label className="text-xs font-semibold text-slate-500 uppercase">Categoría</label>
                <select value={category} onChange={(e) => setCategory(e.target.value)} className="w-full p-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500" required>
                  {(type === 'gasto' ? expenseCategories : incomeCategories).map(cat => (
                    <option key={cat} value={cat}>{cat}</option>
                  ))}
                </select>
              </div>
            )}

            <div>
              <label className="text-xs font-semibold text-slate-500 uppercase">{type === 'transferencia' ? 'Cuenta Origen' : 'Cuenta'}</label>
              <select value={accountId} onChange={(e) => setAccountId(e.target.value)} className="w-full p-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500" required>
                {accounts.map(acc => <option key={acc.id} value={acc.id}>{acc.name} ({formatCurrency(acc.balance)})</option>)}
              </select>
            </div>

            {type === 'transferencia' && (
              <div>
                <label className="text-xs font-semibold text-slate-500 uppercase">Cuenta Destino</label>
                <select value={toAccountId} onChange={(e) => setToAccountId(e.target.value)} className="w-full p-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500" required>
                  {accounts.map(acc => <option key={acc.id} value={acc.id}>{acc.name}</option>)}
                </select>
              </div>
            )}

            <div>
              <label className="text-xs font-semibold text-slate-500 uppercase">Descripción</label>
              <input type="text" value={description} onChange={(e) => setDescription(e.target.value)} placeholder="Ej. Almuerzo" className="w-full p-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500" required />
            </div>

            <button type="submit" className="w-full py-2.5 bg-slate-800 hover:bg-slate-900 text-white font-medium rounded-lg transition-colors text-sm">
              Guardar Movimiento
            </button>
          </form>
        </div>
      </div>

      {/* Historial */}
      <div className="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-100 flex flex-col h-[700px]">
        <div className="p-5 border-b border-slate-100 flex justify-between items-center sticky top-0 bg-white z-10 rounded-t-2xl">
          <h2 className="text-lg font-bold text-slate-800">Historial</h2>
          <span className="text-xs bg-slate-100 px-3 py-1 rounded-full font-medium">{transactions.length} Registros</span>
        </div>
        <div className="overflow-y-auto p-2">
          {transactions.length === 0 ? (
             <div className="h-full flex flex-col items-center justify-center text-slate-400 p-8 text-center mt-20">
               <CreditCard size={48} className="mb-4 text-slate-300" />
               <p>Aún no hay registros.</p>
             </div>
          ) : (
            <ul className="divide-y divide-slate-50">
              {transactions.map(t => {
                const isExpense = t.type === 'gasto';
                const isTransfer = t.type === 'transferencia';
                return (
                  <li key={t.id} className="p-4 hover:bg-slate-50 transition-colors flex items-center justify-between rounded-lg">
                    <div className="flex items-center gap-4">
                      <div className={`p-2.5 rounded-xl ${isExpense ? 'bg-rose-100 text-rose-600' : isTransfer ? 'bg-indigo-100 text-indigo-600' : 'bg-emerald-100 text-emerald-600'}`}>
                        {isExpense ? getCategoryIcon(t.category) : isTransfer ? <ArrowRightLeft size={20}/> : <TrendingUp size={20}/>}
                      </div>
                      <div>
                        <p className="font-semibold text-slate-800">{t.description}</p>
                        <div className="flex gap-2 mt-1 text-xs text-slate-500">
                          <span className="bg-slate-100 px-2 py-0.5 rounded">{t.date}</span>
                          {!isTransfer && <span className="bg-slate-100 px-2 py-0.5 rounded">{t.category}</span>}
                          <span className="bg-slate-100 px-2 py-0.5 rounded font-medium">
                            {accounts.find(a=>a.id === t.accountId)?.name} {isTransfer && `→ ${accounts.find(a=>a.id === t.toAccountId)?.name}`}
                          </span>
                        </div>
                      </div>
                    </div>
                    <div className="flex items-center gap-4">
                      <span className={`font-bold ${isExpense ? 'text-rose-600' : isTransfer ? 'text-slate-700' : 'text-emerald-600'}`}>
                        {isExpense ? '-' : isTransfer ? '' : '+'}{formatCurrency(t.amount)}
                      </span>
                      <button onClick={() => deleteTransaction(t.id)} className="text-slate-300 hover:text-rose-500"><Trash2 size={16}/></button>
                    </div>
                  </li>
                );
              })}
            </ul>
          )}
        </div>
      </div>
    </div>
  );

  const renderCuentasPresupuestos = () => (
    <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {/* SECCIÓN CUENTAS */}
      <div className="space-y-6">
        <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
          <h2 className="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2"><Landmark size={20} className="text-indigo-500"/> Mis Cuentas</h2>
          <div className="space-y-3 mb-6">
            {calculatedAccounts.map(acc => (
              <div key={acc.id} className="p-3 border border-slate-100 rounded-xl hover:bg-slate-50 transition-colors">
                {editingAccount && editingAccount.id === acc.id ? (
                  <form onSubmit={handleUpdateAccount} className="flex flex-col gap-2">
                    <div className="flex gap-2">
                      <input type="text" value={editingAccount.name} onChange={e => setEditingAccount({...editingAccount, name: e.target.value})} className="p-1.5 border rounded-lg text-sm flex-1 bg-white focus:ring-2 focus:ring-indigo-500" required />
                      <select value={editingAccount.type} onChange={e => setEditingAccount({...editingAccount, type: e.target.value})} className="p-1.5 border rounded-lg text-sm bg-white focus:ring-2 focus:ring-indigo-500">
                        <option value="banco">Banco / Ahorros</option>
                        <option value="tarjeta">Tarjeta de Crédito</option>
                        <option value="deuda">Deuda / Préstamo</option>
                      </select>
                    </div>
                    <div className="flex gap-2 items-center">
                      <label className="text-xs text-slate-500 font-semibold uppercase">Saldo Base:</label>
                      <input type="number" value={editingAccount.balance} onChange={e => setEditingAccount({...editingAccount, balance: parseFloat(e.target.value)})} className="p-1.5 border rounded-lg text-sm flex-1 bg-white focus:ring-2 focus:ring-indigo-500" required />
                      <button type="submit" className="bg-emerald-500 hover:bg-emerald-600 text-white px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">Guardar</button>
                      <button type="button" onClick={() => setEditingAccount(null)} className="bg-slate-200 hover:bg-slate-300 text-slate-700 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">Cancelar</button>
                    </div>
                  </form>
                ) : (
                  <div className="flex justify-between items-center">
                    <div>
                      <p className="font-semibold text-slate-800">{acc.name}</p>
                      <span className="text-xs text-slate-500 uppercase bg-slate-100 px-2 py-0.5 rounded">{acc.type}</span>
                    </div>
                    <div className="flex items-center gap-4">
                      <p className={`font-bold text-lg ${acc.currentBalance < 0 ? 'text-rose-600' : 'text-slate-800'}`}>
                        {formatCurrency(acc.currentBalance)}
                      </p>
                      <div className="flex gap-1 bg-white border border-slate-200 rounded-md p-1">
                        <button onClick={() => setEditingAccount({id: acc.id, name: acc.name, type: acc.type, balance: acc.balance})} className="text-slate-400 hover:text-indigo-600 p-1 rounded hover:bg-indigo-50 transition-colors" title="Editar cuenta"><Edit2 size={14}/></button>
                        <button onClick={() => deleteAccount(acc.id)} className="text-slate-400 hover:text-rose-600 p-1 rounded hover:bg-rose-50 transition-colors" title="Eliminar cuenta"><Trash2 size={14}/></button>
                      </div>
                    </div>
                  </div>
                )}
              </div>
            ))}
          </div>
          
          <h3 className="text-sm font-bold text-slate-500 uppercase mb-3">Añadir Cuenta</h3>
          <form onSubmit={addAccount} className="flex flex-col gap-3">
            <input name="accName" type="text" placeholder="Nombre (Ej. Davivienda)" className="p-2 border rounded-lg text-sm focus:ring-2 focus:ring-indigo-500" required/>
            <div className="flex gap-3">
              <select name="accType" className="p-2 border rounded-lg text-sm flex-1">
                <option value="banco">Banco / Ahorros</option>
                <option value="tarjeta">Tarjeta de Crédito</option>
                <option value="deuda">Deuda / Préstamo</option>
              </select>
              <input name="accBalance" type="number" placeholder="Saldo Inicial" className="p-2 border rounded-lg text-sm w-1/3"/>
            </div>
            <button type="submit" className="py-2 bg-indigo-50 text-indigo-600 font-semibold rounded-lg text-sm hover:bg-indigo-100">Crear Cuenta</button>
          </form>
        </div>

        {/* GASTOS FIJOS */}
        <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
          <h2 className="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2"><RefreshCw size={20} className="text-rose-500"/> Gastos Fijos</h2>
          <div className="space-y-3">
            {fixedExpenses.map(expense => (
              <div key={expense.id} className="flex justify-between items-center p-3 border border-slate-100 rounded-xl">
                <div>
                  <p className={`font-semibold ${expense.isPaid ? 'text-slate-400 line-through' : 'text-slate-800'}`}>{expense.title}</p>
                  <p className="text-xs text-slate-500">{expense.category} • {formatCurrency(expense.amount)}</p>
                </div>
                <button 
                  onClick={() => handlePayFixedExpense(expense)}
                  disabled={expense.isPaid}
                  className={`px-3 py-1 rounded-lg text-xs font-bold transition-colors ${expense.isPaid ? 'bg-slate-100 text-slate-400' : 'bg-emerald-500 text-white hover:bg-emerald-600 shadow-sm'}`}
                >
                  {expense.isPaid ? 'Pagado' : 'Pagar Ahora'}
                </button>
              </div>
            ))}
          </div>
        </div>

        {/* GESTIÓN DE CATEGORÍAS */}
        <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
          <h2 className="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2"><MoreHorizontal size={20} className="text-orange-500"/> Mis Categorías</h2>
          
          <div className="mb-4">
            <p className="text-xs font-bold text-slate-500 uppercase mb-2">Gastos</p>
            <div className="flex flex-wrap gap-2 max-h-32 overflow-y-auto p-1">
              {categoriesConfig.filter(c => c.type === 'gasto' || c.type === 'ambos').map(cat => (
                <span key={`gasto-${cat.name}`} className="px-3 py-1 bg-rose-50 text-rose-700 rounded-full text-xs font-medium flex items-center gap-1 border border-rose-100 shadow-sm group transition-all">
                  {getCategoryIcon(cat.name)} {cat.name}
                  <button onClick={() => deleteCategory(cat.name)} className="ml-1 opacity-0 group-hover:opacity-100 hover:text-rose-900 transition-opacity" title="Eliminar categoría"><X size={12}/></button>
                </span>
              ))}
            </div>
          </div>

          <div className="mb-6">
            <p className="text-xs font-bold text-slate-500 uppercase mb-2">Ingresos</p>
            <div className="flex flex-wrap gap-2 max-h-32 overflow-y-auto p-1">
              {categoriesConfig.filter(c => c.type === 'ingreso' || c.type === 'ambos').map(cat => (
                <span key={`ingreso-${cat.name}`} className="px-3 py-1 bg-emerald-50 text-emerald-700 rounded-full text-xs font-medium flex items-center gap-1 border border-emerald-100 shadow-sm group transition-all">
                  {getCategoryIcon(cat.name)} {cat.name}
                  <button onClick={() => deleteCategory(cat.name)} className="ml-1 opacity-0 group-hover:opacity-100 hover:text-emerald-900 transition-opacity" title="Eliminar categoría"><X size={12}/></button>
                </span>
              ))}
            </div>
          </div>
          
          <h3 className="text-sm font-bold text-slate-500 uppercase mb-3">Añadir Nueva Categoría</h3>
          <form onSubmit={addCategory} className="flex flex-col gap-3">
            <input name="catName" type="text" placeholder="Nombre (Ej. Mascotas, Ropa)" className="p-2 border rounded-lg text-sm focus:ring-2 focus:ring-indigo-500" required/>
            <div className="flex gap-3">
              <select name="catType" className="p-2 border rounded-lg text-sm flex-1" required>
                <option value="gasto">Gasto</option>
                <option value="ingreso">Ingreso</option>
                <option value="ambos">Ambos</option>
              </select>
              <button type="submit" className="py-2 px-4 bg-orange-50 text-orange-600 font-semibold rounded-lg text-sm hover:bg-orange-100 whitespace-nowrap transition-colors">Crear Categoría</button>
            </div>
          </form>
        </div>
      </div>

      {/* SECCIÓN PRESUPUESTOS */}
      <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 h-fit">
        <h2 className="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2"><Target size={20} className="text-emerald-500"/> Presupuestos por Categoría</h2>
        
        <form onSubmit={saveBudget} className="flex gap-2 mb-6 p-4 bg-slate-50 rounded-xl">
          <select name="budgetCat" className="p-2 border rounded-lg text-sm flex-1" required>
            <option value="">Seleccionar Categoría...</option>
            {expenseCategories.map(cat => <option key={cat} value={cat}>{cat}</option>)}
          </select>
          <input name="budgetAmount" type="number" placeholder="Límite Mensual" className="p-2 border rounded-lg text-sm w-1/3" required/>
          <button type="submit" className="px-4 bg-slate-800 text-white rounded-lg text-sm font-semibold">Fijar</button>
        </form>

        <div className="space-y-6">
          {Object.entries(budgets).map(([cat, limit]) => {
            const spent = expensesByCategory[cat] || 0;
            const percentage = Math.min((spent / limit) * 100, 100);
            const isOver = spent > limit;
            const isWarning = percentage > 80 && !isOver;

            return (
              <div key={cat} className="space-y-2">
                <div className="flex justify-between items-end">
                  <span className="font-semibold text-slate-700 flex items-center gap-1">{getCategoryIcon(cat)} {cat}</span>
                  <span className={`text-sm font-bold ${isOver ? 'text-rose-600' : 'text-slate-500'}`}>
                    {formatCurrency(spent)} / {formatCurrency(limit)}
                  </span>
                </div>
                <div className="h-3 bg-slate-100 rounded-full overflow-hidden">
                  <div 
                    className={`h-full transition-all duration-500 ${isOver ? 'bg-rose-500' : isWarning ? 'bg-amber-400' : 'bg-emerald-400'}`}
                    style={{ width: `${percentage}%` }}
                  ></div>
                </div>
                {isOver && <p className="text-xs text-rose-500 flex items-center gap-1"><AlertTriangle size={12}/> Te has pasado del presupuesto</p>}
              </div>
            );
          })}
          {Object.keys(budgets).length === 0 && (
            <p className="text-center text-slate-400 text-sm py-8">No has definido presupuestos. Fija uno arriba para empezar a medirte.</p>
          )}
        </div>
      </div>
    </div>
  );

  const renderAnalysis = () => (
    <div className="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 min-h-[500px]">
      <div className="flex flex-col md:flex-row items-center justify-between mb-8 gap-4">
        <div>
          <h2 className="text-2xl font-bold text-slate-800 flex items-center gap-2"><Sparkles className="text-purple-500" /> Análisis con IA</h2>
          <p className="text-slate-500">Gemini analizará tus gastos vs presupuestos y te dará una asesoría.</p>
        </div>
        <button 
          onClick={getCategoryAnalysisWithAI}
          disabled={isAnalysisLoading || Object.keys(expensesByCategory).length === 0}
          className="flex items-center gap-2 px-6 py-3 bg-purple-600 hover:bg-purple-700 disabled:bg-slate-300 text-white rounded-xl font-bold transition-colors shadow-md"
        >
          {isAnalysisLoading ? <Loader2 className="animate-spin" /> : <Lightbulb />}
          Generar Reporte
        </button>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 className="font-bold text-slate-700 mb-4 border-b pb-2">Tu Distribución de Gastos</h3>
          <div className="space-y-3">
            {Object.entries(expensesByCategory).sort((a,b)=>b[1]-a[1]).filter(([_,v])=>v>0).map(([cat, val]) => (
              <div key={cat} className="flex justify-between items-center p-3 bg-slate-50 rounded-lg">
                <span className="text-slate-700 flex items-center gap-2">{getCategoryIcon(cat)} {cat}</span>
                <span className="font-bold text-slate-900">{formatCurrency(val)}</span>
              </div>
            ))}
            {Object.values(expensesByCategory).every(v=>v===0) && <p className="text-slate-400 text-sm">No hay gastos para analizar aún.</p>}
          </div>
        </div>

        <div className="bg-gradient-to-br from-indigo-50 to-purple-50 rounded-2xl p-6 border border-purple-100 relative">
          <h3 className="font-bold text-purple-800 mb-4 flex items-center gap-2"><Wand2 size={18}/> El veredicto de tu Asesor</h3>
          <div className="prose prose-sm text-slate-700 whitespace-pre-wrap">
            {categoryAnalysis ? (
              <p>{categoryAnalysis}</p>
            ) : (
              <p className="text-center text-slate-400 italic mt-10">Haz clic en "Generar Reporte" para recibir consejos personalizados basados en tus números.</p>
            )}
          </div>
        </div>
      </div>
    </div>
  );

  return (
    <div className="min-h-screen bg-slate-50 p-4 md:p-8 font-sans text-slate-800">
      <div className="max-w-6xl mx-auto space-y-6">
        
        {/* Header & Main Stats */}
        <header className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6">
          <div className="flex items-center gap-4">
            <div className="p-3 bg-slate-900 text-white rounded-xl"><PieChart size={32} /></div>
            <div>
              <h1 className="text-2xl font-bold text-slate-900">Mi Control Financiero</h1>
              <p className="text-slate-500 text-sm">Asistente Personal con IA</p>
            </div>
          </div>
          
          <div className="flex flex-wrap items-center gap-4 md:gap-6 w-full lg:w-auto justify-between lg:justify-end border-t border-slate-100 lg:border-none pt-4 lg:pt-0">
        {user && (
          <div className="hidden lg:flex items-center gap-1.5 text-xs font-medium text-slate-500 bg-slate-100 px-3 py-1.5 rounded-full" title="Sincronización en la nube">
            <Cloud size={14} className={isSyncing ? "text-indigo-500 animate-pulse" : "text-emerald-500"} />
            {isSyncing ? "Guardando..." : "Sincronizado"}
          </div>
        )}
        <div className="text-right">
          <p className="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-wider">Ingreso Mes</p>
              <p className="text-base md:text-lg font-bold text-emerald-500">{formatCurrency(monthlyIncome)}</p>
            </div>
            <div className="text-right">
              <p className="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-wider">Gasto Mes</p>
              <p className="text-base md:text-lg font-bold text-rose-500">{formatCurrency(monthlyExpense)}</p>
            </div>
            <div className="text-right">
              <p className="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-wider">Gasto Sem.</p>
              <p className="text-base md:text-lg font-bold text-orange-500">{formatCurrency(weeklyExpense)}</p>
            </div>
            
            <div className="hidden md:block w-px h-8 bg-slate-200"></div>
            
            <div className="text-right">
              <p className="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-wider">Activos</p>
              <p className="text-base md:text-lg font-bold text-emerald-600">{formatCurrency(totalAssets)}</p>
            </div>
            <div className="text-right">
              <p className="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-wider">Pasivos</p>
              <p className="text-base md:text-lg font-bold text-rose-600">{formatCurrency(Math.abs(totalLiabilities))}</p>
            </div>
            
            <button onClick={exportToCSV} className="hidden xl:flex items-center gap-2 px-3 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg transition-colors font-semibold text-sm ml-2">
              <Download size={16} /> Exportar
            </button>
          </div>
        </header>

        {/* Navegación por Pestañas */}
        <div className="flex gap-2 overflow-x-auto pb-2">
          <button onClick={() => setActiveTab('movimientos')} className={`px-5 py-2.5 rounded-xl font-semibold text-sm flex items-center gap-2 transition-all ${activeTab === 'movimientos' ? 'bg-indigo-600 text-white shadow-md' : 'bg-white text-slate-600 hover:bg-slate-100'}`}>
            <Wallet size={18} /> Movimientos
          </button>
          <button onClick={() => setActiveTab('cuentas')} className={`px-5 py-2.5 rounded-xl font-semibold text-sm flex items-center gap-2 transition-all ${activeTab === 'cuentas' ? 'bg-indigo-600 text-white shadow-md' : 'bg-white text-slate-600 hover:bg-slate-100'}`}>
            <Landmark size={18} /> Cuentas & Presupuestos
          </button>
          <button onClick={() => setActiveTab('analisis')} className={`px-5 py-2.5 rounded-xl font-semibold text-sm flex items-center gap-2 transition-all ${activeTab === 'analisis' ? 'bg-purple-600 text-white shadow-md' : 'bg-white text-slate-600 hover:bg-slate-100'}`}>
            <Sparkles size={18} /> Análisis IA
          </button>
        </div>

        {/* Contenido de la Pestaña Activa */}
        <main className="animate-in fade-in duration-300">
          {activeTab === 'movimientos' && renderMovimientos()}
          {activeTab === 'cuentas' && renderCuentasPresupuestos()}
          {activeTab === 'analisis' && renderAnalysis()}
        </main>

      </div>
    </div>
  );
};

export default App;
